# AuditTrace-AI — Environment Configuration
# Copy to .env and fill in your values
# Generate secrets with: ./scripts/setup-secrets.sh

# Environment: "local" (Docker Compose), "production", "test" (mocks)
AUDITTRACE_ENV=local

# Server
AUDITTRACE_HOST=0.0.0.0
AUDITTRACE_PORT=8765
AUDITTRACE_WORKERS=1
AUDITTRACE_LOG_LEVEL=INFO

# LLM Servers (on host machine, outside Docker)
AUDITTRACE_LLAMA_URL=http://host.docker.internal:11435/v1
AUDITTRACE_EMBED_URL=http://host.docker.internal:11436/v1

# ADR-034 — Long-running generation support.
# Per-chunk idle timeout (seconds). If no SSE chunk arrives within this
# window, the stream is considered stalled → 504 + audit row. As long as
# tokens keep flowing (even during <think> reasoning), the stream stays
# alive indefinitely.
AUDITTRACE_LLAMA_CHUNK_TIMEOUT=120
# SSE keep-alive comment frames (seconds). Emitted during quiet periods
# to hold connections through reverse proxies and signal liveness.
AUDITTRACE_SSE_KEEPALIVE_INTERVAL=15

# ADR-030 — dedicated summariser endpoint (Mistral 7B Instruct v0.3 on :11437).
# Separate process so background summarisation does not contend with the
# interactive tool-loop on the Qwen slot. See scripts/start-summarizer-llama.sh.
AUDITTRACE_SUMMARIZER_URL=http://host.docker.internal:11437/v1
AUDITTRACE_SUMMARIZER_MODEL=mistral-7b-summarizer
AUDITTRACE_SUMMARIZER_ENABLED=true
AUDITTRACE_SUMMARIZER_IDLE_MINUTES=15
AUDITTRACE_SUMMARIZER_INTERVAL_MINUTES=5
AUDITTRACE_SUMMARIZER_MAX_PER_CYCLE=10
# Owner-role connection for RLS bypass during the cross-user
# eligibility read. See docker-compose.yml for the composed value.
AUDITTRACE_SUMMARIZER_POSTGRES_URL=

# ChromaDB — server mode with token auth (ADR-019, ADR-020)
AUDITTRACE_CHROMA_URL=http://chromadb:8000
AUDITTRACE_CHROMA_COLLECTION=audittrace_memory
AUDITTRACE_CHROMA_TOKEN=

# OAuth2 Device Flow (ADR-032) — accept tokens with the Traefik-fronted
# issuer in addition to the internal docker-network issuer. Pydantic
# expects a JSON array literal for list[str] env vars.
AUDITTRACE_KEYCLOAK_ISSUER_EXTRAS=["http://localhost/realms/audittrace","https://localhost/realms/audittrace"]

# PostgreSQL (ADR-020)
AUDITTRACE_POSTGRES_URL=
AUDITTRACE_POSTGRES_DB=audittrace
AUDITTRACE_POSTGRES_USER=audittrace
AUDITTRACE_POSTGRES_PASSWORD=
AUDITTRACE_POSTGRES_HOST=postgres
AUDITTRACE_POSTGRES_PORT=5432

# Langfuse Observability (ADR-021.2)
AUDITTRACE_LANGFUSE_HOST=http://langfuse-web:3000
AUDITTRACE_LANGFUSE_PUBLIC_KEY=
AUDITTRACE_LANGFUSE_SECRET_KEY=
AUDITTRACE_LANGFUSE_ENABLED=false

# OpenTelemetry (ADR-014.4, ADR-028)
# OTLP export → OTel Collector for metrics + logs.
# Traces go to Langfuse via SDK (not OTLP).
AUDITTRACE_OTLP_ENDPOINT=http://otel-collector:4318
AUDITTRACE_OTEL_SERVICE_NAME=audittrace-server
AUDITTRACE_TRACING_ENABLED=true
AUDITTRACE_METRICS_ENABLED=true

# OAuth2 / Keycloak (ADR-022, ADR-023)
AUDITTRACE_AUTH_ENABLED=true
AUDITTRACE_KEYCLOAK_URL=http://keycloak:8080
AUDITTRACE_KEYCLOAK_REALM=audittrace
AUDITTRACE_KEYCLOAK_ISSUER=http://keycloak:8080/realms/audittrace
AUDITTRACE_KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/audittrace/protocol/openid-connect/certs
AUDITTRACE_JWT_AUDIENCE=audittrace-server
KEYCLOAK_ADMIN_PASSWORD=admin

# MinIO S3 Object Storage (ADR-027)
# Replaces filesystem bind mounts for memory layers 1+2.
# Encryption at rest via SSE-S3 (MINIO_KMS_SECRET_KEY).
AUDITTRACE_MINIO_URL=http://minio:9000
AUDITTRACE_MINIO_ACCESS_KEY=minioadmin
AUDITTRACE_MINIO_SECRET_KEY=
AUDITTRACE_MINIO_SHARED_BUCKET=memory-shared
AUDITTRACE_MINIO_PRIVATE_BUCKET=memory-private
AUDITTRACE_MINIO_KMS_KEY=

# Memory Configuration
AUDITTRACE_MEMORY_CACHE_TTL=3600
AUDITTRACE_MEMORY_MAX_CONTEXT_TURNS=117000
AUDITTRACE_MEMORY_EMBEDDING_DIM=1024

# Security
AUDITTRACE_CORS_ORIGINS=["https://localhost","http://localhost:8765","http://localhost:3000"]
AUDITTRACE_RATE_LIMIT_REQUESTS=100
AUDITTRACE_RATE_LIMIT_WINDOW=60
