# AuditTrace-AI — Environment Configuration
# Copy to .env and fill in your values
# Generate secrets with: ./scripts/setup-secrets.sh

# Environment: "local" (Docker Compose), "production", "test" (mocks)
SOVEREIGN_ENV=local

# Server
SOVEREIGN_HOST=0.0.0.0
SOVEREIGN_PORT=8765
SOVEREIGN_WORKERS=1
SOVEREIGN_LOG_LEVEL=INFO

# LLM Servers (on host machine, outside Docker)
SOVEREIGN_LLAMA_URL=http://host.docker.internal:11435/v1
SOVEREIGN_EMBED_URL=http://host.docker.internal:11436/v1

# ADR-030 — dedicated summariser endpoint (Mistral 7B Instruct v0.3 on :11437).
# Separate process so background summarisation does not contend with the
# interactive tool-loop on the Qwen slot. See scripts/start-summarizer-llama.sh.
SOVEREIGN_SUMMARIZER_URL=http://host.docker.internal:11437/v1
SOVEREIGN_SUMMARIZER_MODEL=mistral-7b-summarizer
SOVEREIGN_SUMMARIZER_ENABLED=true
SOVEREIGN_SUMMARIZER_IDLE_MINUTES=15
SOVEREIGN_SUMMARIZER_INTERVAL_MINUTES=5
SOVEREIGN_SUMMARIZER_MAX_PER_CYCLE=10
# Owner-role connection for RLS bypass during the cross-user
# eligibility read. See docker-compose.yml for the composed value.
SOVEREIGN_SUMMARIZER_POSTGRES_URL=

# ChromaDB — server mode with token auth (ADR-019, ADR-020)
SOVEREIGN_CHROMA_URL=http://chromadb:8000
SOVEREIGN_CHROMA_COLLECTION=sovereign_memory
SOVEREIGN_CHROMA_TOKEN=

# OAuth2 Device Flow (ADR-032) — accept tokens with the Traefik-fronted
# issuer in addition to the internal docker-network issuer. Pydantic
# expects a JSON array literal for list[str] env vars.
SOVEREIGN_KEYCLOAK_ISSUER_EXTRAS=["http://localhost/realms/sovereign-ai","https://localhost/realms/sovereign-ai"]

# PostgreSQL (ADR-020)
SOVEREIGN_POSTGRES_URL=
SOVEREIGN_POSTGRES_DB=sovereign_ai
SOVEREIGN_POSTGRES_USER=sovereign
SOVEREIGN_POSTGRES_PASSWORD=
SOVEREIGN_POSTGRES_HOST=postgres
SOVEREIGN_POSTGRES_PORT=5432

# Langfuse Observability (ADR-021.2)
SOVEREIGN_LANGFUSE_HOST=http://langfuse-web:3000
SOVEREIGN_LANGFUSE_PUBLIC_KEY=
SOVEREIGN_LANGFUSE_SECRET_KEY=
SOVEREIGN_LANGFUSE_ENABLED=false

# OpenTelemetry (ADR-014.4, ADR-028)
# OTLP export → OTel Collector for metrics + logs.
# Traces go to Langfuse via SDK (not OTLP).
SOVEREIGN_OTLP_ENDPOINT=http://otel-collector:4318
SOVEREIGN_OTEL_SERVICE_NAME=sovereign-memory-server
SOVEREIGN_TRACING_ENABLED=true
SOVEREIGN_METRICS_ENABLED=true

# OAuth2 / Keycloak (ADR-022, ADR-023)
SOVEREIGN_AUTH_ENABLED=false
SOVEREIGN_KEYCLOAK_URL=http://keycloak:8080
SOVEREIGN_KEYCLOAK_REALM=sovereign-ai
SOVEREIGN_KEYCLOAK_ISSUER=http://keycloak:8080/realms/sovereign-ai
SOVEREIGN_KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/sovereign-ai/protocol/openid-connect/certs
SOVEREIGN_JWT_AUDIENCE=sovereign-memory-server
KEYCLOAK_ADMIN_PASSWORD=admin

# MinIO S3 Object Storage (ADR-027)
# Replaces filesystem bind mounts for memory layers 1+2.
# Encryption at rest via SSE-S3 (MINIO_KMS_SECRET_KEY).
SOVEREIGN_MINIO_URL=http://minio:9000
SOVEREIGN_MINIO_ACCESS_KEY=minioadmin
SOVEREIGN_MINIO_SECRET_KEY=
SOVEREIGN_MINIO_SHARED_BUCKET=memory-shared
SOVEREIGN_MINIO_PRIVATE_BUCKET=memory-private
SOVEREIGN_MINIO_KMS_KEY=

# Memory Configuration
SOVEREIGN_MEMORY_CACHE_TTL=3600
SOVEREIGN_MEMORY_MAX_CONTEXT_TURNS=117000
SOVEREIGN_MEMORY_EMBEDDING_DIM=1024

# Security
SOVEREIGN_CORS_ORIGINS=["https://localhost","http://localhost:8765","http://localhost:3000"]
SOVEREIGN_RATE_LIMIT_REQUESTS=100
SOVEREIGN_RATE_LIMIT_WINDOW=60
