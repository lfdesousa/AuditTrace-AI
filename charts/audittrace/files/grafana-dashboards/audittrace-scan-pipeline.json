{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "RabbitMQ — Messages Published (rate, last 5m)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(rabbitmq_global_messages_acknowledged_total[5m]))",
          "legendFormat": "msgs/s acked"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "RabbitMQ — Active Consumers",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rabbitmq_global_consumers)",
          "legendFormat": "consumers"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "RabbitMQ — Publish vs Deliver Rate",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(rabbitmq_channel_messages_published_total[5m]))",
          "legendFormat": "published/s"
        },
        {
          "refId": "B",
          "expr": "sum(rate(rabbitmq_channel_messages_delivered_total[5m]))",
          "legendFormat": "delivered/s"
        },
        {
          "refId": "C",
          "expr": "sum(rate(rabbitmq_channel_messages_acked_total[5m]))",
          "legendFormat": "acked/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Redis — Memory Used",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Redis — Cache Hit Rate (%)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (rate(redis_keyspace_hits_total[5m])) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))",
          "legendFormat": "hit %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Redis — Connected Clients + Evictions",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "redis_connected_clients",
          "legendFormat": "clients"
        },
        {
          "refId": "B",
          "expr": "rate(redis_evicted_keys_total[5m])",
          "legendFormat": "evictions/s"
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Scan Pipeline — Time-Aligned Log Feed (memory-server + rabbitmq + content-control)",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=~\"audittrace|audittrace-content-control|rabbitmq\"} |~ \"(?i)scan|verdict|publish|consume|amqp|reject\"",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["audittrace-ai", "scan-pipeline", "adr-048", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AuditTrace-AI — Scan Pipeline + Cache",
  "uid": "audittrace-scan-pipeline",
  "version": 1
}
