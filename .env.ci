# .env.ci — CI parameterisation surface for the compose stack.
#
# Used by .github/workflows/e2e-compose.yml (B7 step 4) as the
# canonical "what env vars does the compose stack need in CI" file.
# Committed to the repo because it contains no secrets — only
# deterministic test values designed for ephemeral CI runs.
#
# Operators DO NOT use this file directly. For local dev:
#   - Real-LLM (host llama-server): copy .env.dev-real-llm.example
#     to .env, edit secrets, then docker compose up -d.
#   - Mock-LLM (no host LLM): copy .env.ci to .env or set
#     COMPOSE_PROFILES=mock-llm in your shell.
#
# Anchor: docs/architecture/b7-docker-compose-revive-plan.md §5.

# ── Profile selection (Q1 — compose profiles) ──────────────────────
# Activate the in-network mock LLM so the stack doesn't need a host
# llama-server. Step 4 will set this in the GHA workflow env.
COMPOSE_PROFILES=mock-llm

# ── memory-server image (B7 step 1 — published multi-arch) ─────────
# Pinned for determinism; defaults to 1.0.22 in docker-compose.yml
# if unset. Bumping CI to a newer release is a one-line .env.ci
# bump + the test surface remains identical because the LLM contract
# is mocked.
AUDITTRACE_IMAGE_TAG=1.0.22

# ── Storage credentials (test-only, no operational value) ──────────
AUDITTRACE_POSTGRES_PASSWORD=test-postgres-password
AUDITTRACE_REDIS_PASSWORD=test-redis-password
AUDITTRACE_CHROMA_TOKEN=test-chroma-token
AUDITTRACE_RABBITMQ_PASSWORD=test-rabbitmq-password

# MinIO requires a 32-char secret + a base64-encoded 32-byte KMS key.
# These are throwaway dev-fixed values; ephemeral CI volumes ensure
# no persistence concerns.
AUDITTRACE_MINIO_ACCESS_KEY=minioadmin
AUDITTRACE_MINIO_SECRET_KEY=test-minio-secret-key-32chars!!
AUDITTRACE_MINIO_KMS_KEY=dGVzdC1rbXMta2V5LWV4YWN0bHktMzItYnl0ZXMhISE=

# Keycloak admin — only the admin UI uses this; the compose stack
# auto-imports the audittrace realm with the device-flow client
# already wired.
KEYCLOAK_ADMIN_PASSWORD=admin

# ── App env — CI defaults (B7 plan §5) ─────────────────────────────
# Auth bypass: CI exercises the proxy/RLS pipeline; the JWT auth
# path itself is unit-tested separately (1200+ unit tests). Setting
# both to false matches the existing e2e.yml posture.
AUDITTRACE_AUTH_ENABLED=false
AUDITTRACE_AUTH_REQUIRED=false

# Logging — INFO keeps CI logs readable while still revealing
# lifecycle events. Dev defaults to DEBUG (see .env.dev-real-llm.example).
AUDITTRACE_LOG_LEVEL=INFO

# Observability — disabled in CI by default (Q4 decision: obs is
# dev-opt-in only). Step 4's workflow doesn't bring up otel/tempo/
# loki/grafana/langfuse. AUDITTRACE_OTLP_ENDPOINT empty → no OTel
# export attempt; AUDITTRACE_LANGFUSE_ENABLED=false → no Langfuse
# tracer install.
AUDITTRACE_OTLP_ENDPOINT=
AUDITTRACE_LANGFUSE_ENABLED=false

# Summariser — disabled in CI so the background ctx-window scan
# doesn't fire against the deterministic-empty test DB and trip
# spurious "no eligible sessions" log noise. The summariser code
# path is unit-tested elsewhere (test_session_summarizer.py).
AUDITTRACE_SUMMARIZER_ENABLED=false

# Scan-request pipeline — enabled so memory-server's lifespan
# exercises the RabbitMQ connect (B7 step 1's load-bearing test).
AUDITTRACE_SCAN_PIPELINE_ENABLED=true

# ── LLM URLs ───────────────────────────────────────────────────────
# All three resolve to the in-network mock-llm service (port 11435
# serves /v1/models + /v1/chat/completions + /v1/embeddings — the
# mock script in tests/integration/fixtures/compose/mock-llm/server.py
# returns canned responses, byte-identical to the kind CI fixture).
# docker-compose.yml has these as ${VAR:-default} substitutions
# pointing at the mock by default — these explicit lines pin them
# in case docker-compose.yml's defaults ever change.
AUDITTRACE_LLAMA_URL=http://mock-llm:11435/v1
AUDITTRACE_EMBED_URL=http://mock-llm:11435/v1
AUDITTRACE_SUMMARIZER_URL=http://mock-llm:11435/v1
AUDITTRACE_SUMMARIZER_MODEL=audittrace-default

# ── Profile-gated service credentials (B7 steps 6-9) ───────────────
# These are referenced from profile-gated services. CI runs without
# these profiles by default; the values exist so compose substitution
# doesn't warn about unset vars on profile-inactive renders.
AUDITTRACE_VAULT_DEV_TOKEN=audittrace-dev-token
AUDITTRACE_GRAFANA_PASSWORD=admin
AUDITTRACE_LANGFUSE_DB_PASSWORD=langfuse-dev-password
AUDITTRACE_LANGFUSE_NEXTAUTH_SECRET=langfuse-dev-nextauth-secret-32chars-min!!
AUDITTRACE_LANGFUSE_SALT=langfuse-dev-salt-32chars-min-padding!!
AUDITTRACE_CC_RABBITMQ_USER=content-control
AUDITTRACE_CC_RABBITMQ_PASSWORD=cc-dev-password
