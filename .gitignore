chroma_data/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Local agent config (your IP)
.opencode/

# Project-local CLAUDE.md — personal orientation file for Claude Code sessions,
# not a shared project artefact. AGENTS.md is the shared equivalent.
/CLAUDE.md

# Personal skill library (your IP) — seeded into procedural memory at runtime,
# must not be committed. SKILL-memory-commands.md is project-local, keep it.
memory/procedural/SKILL-*.md
!memory/procedural/SKILL-memory-commands.md

# Generated artifacts
coverage.xml
junit.xml
test_data/

# Throwaway artefacts — eval JSONLs, smoke traces, ad-hoc Python probes,
# diagnostic dumps. Never committed; if something here matters it gets
# promoted to docs/ or scripts/. Listed because `git add -A` was caught
# accidentally staging these on 2026-04-26.
/tmp/

# Client keys (generated by scripts/generate-client-keys.sh)
keys/
.structurizr/
istio-1.29.2/

# Per-deployment Helm values — holds dev secrets + the operator's
# hostname overrides (e.g. audittrace.allaboutdata.eu for Google
# federation). Each operator maintains their own; never committed.
charts/audittrace/values-local.yaml
