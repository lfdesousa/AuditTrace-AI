# .env.dev-real-llm.example — operator template for local dev
# against a real host-running llama-server.
#
# USAGE
#   1. Copy:    cp .env.dev-real-llm.example .env
#   2. Edit:    fill in real values for the marked ###CHANGE### lines
#   3. Run:     docker compose up -d
#               (mock-llm profile NOT activated — the stack reaches
#                out to your host's llama-server via host.docker.internal)
#
# This file is committed AS AN EXAMPLE only. Your real .env is
# gitignored (per .gitignore line `.env`). Don't paste real
# credentials into this template.
#
# Anchor: docs/architecture/b7-docker-compose-revive-plan.md §5.

# ── Profile selection (real-LLM dev) ───────────────────────────────
# Leave COMPOSE_PROFILES UNSET (or set to ""). Without `mock-llm`
# in the profile list, the mock-llm service stays dormant and
# memory-server reaches out to host.docker.internal for the LLM.
# Add `obs` (or `obs,langfuse`) to opt into the observability stack
# (when B7 step 7 lands).
COMPOSE_PROFILES=

# ── memory-server image ────────────────────────────────────────────
# Set to the published tag you want to run, or set to "dev" and use
# the docker-compose.dev.yml overlay for local build + hot-reload.
AUDITTRACE_IMAGE_TAG=1.0.22

# ── Storage credentials ────────────────────────────────────────────
# Generate fresh passwords for each operator install. Never share
# the .env file or copy these values across machines.
AUDITTRACE_POSTGRES_PASSWORD=###CHANGE### # e.g. openssl rand -hex 24
AUDITTRACE_REDIS_PASSWORD=###CHANGE###
AUDITTRACE_CHROMA_TOKEN=###CHANGE### # any opaque string ≥ 16 chars
AUDITTRACE_RABBITMQ_PASSWORD=###CHANGE###

# MinIO: ACCESS_KEY is the username (default is fine); SECRET_KEY
# is the password (≥ 8 chars). KMS_KEY must be a 32-byte value
# base64-encoded — generate with:
#   python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
AUDITTRACE_MINIO_ACCESS_KEY=minioadmin
AUDITTRACE_MINIO_SECRET_KEY=###CHANGE### # ≥ 8 chars
AUDITTRACE_MINIO_KMS_KEY=###CHANGE### # base64(32 random bytes)

# Keycloak admin password — keeps the admin UI usable for realm
# inspection. The OAuth Device Flow client (audittrace-opencode)
# is pre-imported by the chart's realm-audittrace.json.
KEYCLOAK_ADMIN_PASSWORD=###CHANGE###

# ── App env — dev defaults ─────────────────────────────────────────
# Auth ENABLED in dev so you exercise the full JWT validation path.
# Set to false ONLY if you're iterating on something orthogonal to
# auth and want to skip token fetches (use AUDITTRACE_AUTH_REQUIRED=
# false for "auth-bypass, no JWT needed" — same posture as .env.ci).
AUDITTRACE_AUTH_ENABLED=true
AUDITTRACE_AUTH_REQUIRED=true

# Verbose logging is the right dev default. CI uses INFO.
AUDITTRACE_LOG_LEVEL=DEBUG

# Observability — opt-in. Set if you've activated the `obs` profile
# (otel-collector + tempo + loki + grafana). Empty = no OTel export.
AUDITTRACE_OTLP_ENDPOINT=
AUDITTRACE_LANGFUSE_ENABLED=false
AUDITTRACE_LANGFUSE_PUBLIC_KEY=
AUDITTRACE_LANGFUSE_SECRET_KEY=

# Summariser — enabled for dev so you actually see the background
# loop run against your sessions. Set to false if you don't want
# the periodic summariser ctx-window scan in your logs.
AUDITTRACE_SUMMARIZER_ENABLED=true

# Scan-request pipeline (RabbitMQ-driven content-control hand-off).
# Required for /memory/upload to work end-to-end. Keep true unless
# you're isolating something orthogonal.
AUDITTRACE_SCAN_PIPELINE_ENABLED=true

# ── LLM URLs — real llama-server on the host ───────────────────────
# Default ports per ADR-030 (chat=11435, embed=11436, summariser=11437).
# `host.docker.internal` resolves to the dev box's gateway IP via
# docker-compose.yml's `extra_hosts:` directive on memory-server.
# Adjust the ports if your llama-server is on different ones.
AUDITTRACE_LLAMA_URL=http://host.docker.internal:11435/v1
AUDITTRACE_EMBED_URL=http://host.docker.internal:11436/v1
AUDITTRACE_SUMMARIZER_URL=http://host.docker.internal:11437/v1

# Model name surfaced via /v1/models and used as the default for
# /v1/chat/completions. Set to whatever your host llama-server
# reports — typically the GGUF filename.
AUDITTRACE_SUMMARIZER_MODEL=mistral-7b-summarizer
